{
  "http-request": {
    "path": "/findAvailableProducts",
    "method": "GET",
    "query": {
      "from-date": "2026-02-15",
      "to-date": "2026-02-15",
      "type": "book"
    },
    "headers": {
      "pageSize": "10"
    }
  },
  "http-response": {
    "status": 200,
    "body": [
      {
        "id": "$match(productid: number)",
        "name": "$match(productname: string)",
        "type": "$match(type: string)",
        "inventory": "$match(productinventory: number)",
        "createdOn": "$match(productcreatedon: date)"
      }
    ],
    "status-text": "OK",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
